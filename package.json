    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "read-excel-file": "9.3.2",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^3.8.0",
    "resend": "^6.17.2",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
