    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.30.1",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.19",
    "prettier": "3.6.2",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.20.3",
    "typescript": "5.7.3"
