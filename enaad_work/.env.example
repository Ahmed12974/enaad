# PostgreSQL connection used by the application and Better Auth.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/lughati
DATABASE_POOL_MAX=5
# Set to "require" only when the provider supplies a certificate chain trusted by Node.js.
DATABASE_SSL=

# Generate once with: openssl rand -base64 32
# Keep the same value across deployments. Never commit the real value.
BETTER_AUTH_SECRET=replace-with-a-stable-random-secret-at-least-32-characters

# Exact origins only; no path and no wildcard.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional exact reverse-proxy IPs/CIDRs. Set only when your origin accepts traffic exclusively from those proxies.
AUTH_TRUSTED_PROXIES=

# Optional email delivery. Use onboarding@resend.dev only for testing to the Resend account email; use a verified custom domain for general delivery.
# Do not use a Gmail address here. Missing email settings no longer block deployment.
RESEND_API_KEY=
EMAIL_FROM=Lughati <onboarding@resend.dev>

# Optional Vercel Blob uploads.
BLOB_READ_WRITE_TOKEN=

# Optional one-time administrator promotion script input.
INITIAL_ADMIN_EMAIL=enaad4786@gmail.com

# Test-only. Never enable against production data. It permits Playwright to provision
# and restore exact authorization fixtures for the sole administrator account.
E2E_ALLOW_ADMIN_FIXTURE=0
